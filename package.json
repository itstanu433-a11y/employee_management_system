{
  "name": "employee-management-system",
  "version": "1.0.0",
  "description": "Modern Employee Management System with React and JSON Server",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.14.0",
    "axios": "^1.4.0",
    "react-hook-form": "^7.45.0",
    "@mui/material": "^5.13.0",
    "@mui/icons-material": "^5.13.0",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "recharts": "^2.10.0",
    "react-icons": "^4.10.0",
    "react-toastify": "^9.1.0",
    "zustand": "^4.3.0"
  },
  "devDependencies": {
    "react-scripts": "5.0.1",
    "json-server": "^0.17.3",
    "web-vitals": "^2.1.4"
